# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-me-in-production-use-32-chars-minimum
APP_NAME=ESG Auditor
APP_VERSION=1.0.0

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – development)
DATABASE_URL=sqlite+aiosqlite:///./data/esg_auditor.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/esg_auditor
DB_ECHO=false

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# ── ML Models ─────────────────────────────────────────────────────────────────
MODEL_DIR=./ml/models
MODEL_PATH=./ml/models/esg_xgb_v1.pkl
PIPELINE_PATH=./ml/models/feature_pipeline.pkl
AUTO_TRAIN_MODEL=true

# ── NLP / Zero-Shot ───────────────────────────────────────────────────────────
ZERO_SHOT_MODEL=facebook/bart-large-mnli
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
DEVICE=cpu
MAX_TEXTS_FOR_ZERO_SHOT=10
EMERGING_RISK_THRESHOLD=0.35

# ── Vector Store ──────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index

# ── Agents ────────────────────────────────────────────────────────────────────
VERBOSE_AGENTS=false
AGENT_MAX_ITER=5

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=./outputs
ENABLE_PDF_REPORTS=false
TEMPLATES_DIR=./templates

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=./data

# ── External APIs (all optional – system works without them) ──────────────────
NEWS_API_KEY=
OPENAI_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=./logs/esg_auditor.log

# ── Monitoring ────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
PROMETHEUS_PORT=9090