{
    "id": null,
    "uid": "esg-auditor-main",
    "title": "ESG Auditor Platform",
    "tags": ["esg", "ml", "api"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "30s",
    "time": {"from": "now-1h", "to": "now"},
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"esg-api\"}[1m])",
            "legendFormat": "{{method}} {{handler}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "API Response Time (p95)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"esg-api\"}[5m]))",
            "legendFormat": "p95 {{handler}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s", "color": {"mode": "palette-classic"}},
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "HTTP Status Code Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum by (status_code) (rate(http_requests_total{job=\"esg-api\"}[5m]))",
            "legendFormat": "{{status_code}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "API Error Rate",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"esg-api\", status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx errors/s",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.1}
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 5,
        "title": "Active Audits (Running)",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "esg_audits_running_total",
            "legendFormat": "Running",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          },
          "overrides": []
        }
      }
    ]
  }